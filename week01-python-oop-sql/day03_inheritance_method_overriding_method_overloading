
################################ METHOD OVERLOADING ################################

"""
Method Overloading:
Method overloading means having multiple methods with the same name but different parameters. 
Python does not support traditional method overloading; 
it is usually simulated using default arguments, *args, or **kwargs.
Definition: Same method name with different parameters
Purpose: Handle different input combinations
"""

class CalculatorZ:

    def add(self, a, b):
        return a + b
    
    def add(self, a, b, c=0):
        return a + b + c
    
    # Here 1st add method is overwritten by 2nd add method.

calc = CalculatorZ()
print(">>", calc.add(4,5))

# Instead of CalculatorZ, the below class Calculator is well written.

class Calculator:

    def add(self, *args):
        return sum(args)
    
a = Calculator()
print(a)
print(a.add(40,30,20))
print(a)

