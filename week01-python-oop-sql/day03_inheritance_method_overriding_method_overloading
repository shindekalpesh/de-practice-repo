"""
Inheritance, Method overriding

There are three types of Inheritance:
1. Single inheritance:
    A -> B              : One level
2. Multi-level inheritance
    A -> B -> C         : Single level of classes      
3. Multiple inheritance
    A -> C and B -> C   : Two/mutliple parent class and one child class

Method Overriding:
Method overriding occurs when a child class provides its own implementation of a method already defined in the parent class. 
It is fully supported in Python and is used to achieve runtime polymorphism through inheritance.
Definition: Child class provides its own implmentation of a parent class.
Purpose: Change or extend inherited (from Parent class) behaviour.

"""

# 1. Single inheritance:
class Car:                      # Base/Parent class

    def __init__(self, fuel, color):
        self.fuel = fuel
        self.color = color

    @staticmethod
    def start():
        return "Car has started..."

    @staticmethod
    def stop():
        return "Car has stopped..."


c1 = Car("Diesel", "White")
# print(c1.fuel)
# print(c1.start())
# print(c1.stop())


class Skoda(Car):           # Derived/Child class

    def __init__(self, fuel, color, name, variant):
        super().__init__(fuel, color)
        self.name = name
        self.variant = variant

c2 = Skoda("Diesel", "Black", "Kodiaq", "Top")

