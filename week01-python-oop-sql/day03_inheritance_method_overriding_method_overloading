# 2. Multi-level inheritance:

# Using the above 'Car' Parent class:

class Transmission(Skoda):

    def __init__(self, fuel, color, name, variant, transmission):
        super().__init__(fuel, color, name, variant)
        self.fuel = fuel
        self.color = color
        self.name = name
        self.variant = variant
        self.transmission = transmission


c3 = Transmission("Petrol", "Gray", "Octavia", "Top", "Automatic")
