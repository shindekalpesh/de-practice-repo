# 3. Multiple inheritance:

# Using the above 'Car' Parent class:

class Price(Car):
    
    def __init__(self, fuel, color, ex_showroom_price):
        super().__init__(fuel, color)
        self.ex_showroom_price = ex_showroom_price
        # self.on_road_price = self.ex_showroom_price + (self.ex_showroom_price * 0.27)   # There's a problem here. If ex_showroom_price is updated, on_road_price does not get updated automatically. 

    def start(self):                # This is called Method Overriding achieved through Inheritance. The Parent class's start() method got overridden by child class's own start() method.
        return "This car ROARS with price tag!"

    
    
c4 = Price("Petrol", "Gray", 1000000)
print("--------- Multi-level Inheritance ---------")
print("c4.fuel", type(c4.fuel), c4.fuel)
print("c4.color", type(c4.color), c4.color)
print("c4.ex_showroom_price", type(c4.ex_showroom_price), c4.ex_showroom_price)
